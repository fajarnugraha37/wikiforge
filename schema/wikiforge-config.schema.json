{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/fajarnugraha37/wikiforge/main/schema/wikiforge-config.schema.json",
  "title": "WikiForge Configuration",
  "type": "object",
  "required": [
    "version",
    "openwiki",
    "components"
  ],
  "properties": {
    "version": {
      "type": "integer",
      "enum": [
        3
      ]
    },
    "workspace": {
      "type": "string"
    },
    "openwiki": {
      "type": "object",
      "required": [
        "command"
      ],
      "properties": {
        "command": {
          "type": "string",
          "minLength": 1
        },
        "args": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "modelId": {
          "type": "string"
        },
        "timeoutMinutes": {
          "type": "integer",
          "minimum": 1
        },
        "maxCaptureBytes": {
          "type": "integer",
          "minimum": 1024
        },
        "logDirectory": {
          "type": "string"
        },
        "environment": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "execution": {
      "type": "object",
      "properties": {
        "parallelComponents": {
          "type": "integer",
          "minimum": 1
        },
        "maxProcessRetries": {
          "type": "integer",
          "minimum": 0
        },
        "maxRepairRounds": {
          "type": "integer",
          "minimum": 0
        },
        "continueOnComponentFailure": {
          "type": "boolean"
        },
        "isolateSameRepository": {
          "type": "boolean",
          "description": "Run scoped components from one repository in isolated staging worktrees when safe."
        }
      },
      "additionalProperties": false
    },
    "documentation": {
      "type": "object",
      "properties": {
        "language": {
          "type": "string",
          "minLength": 1
        },
        "minimumQualityScore": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100
        },
        "minimumPages": {
          "type": "integer",
          "minimum": 0
        },
        "requireFrontMatter": {
          "type": "boolean"
        },
        "requireSourceReferences": {
          "type": "boolean"
        },
        "validateSourcePaths": {
          "type": "boolean"
        },
        "requireMermaid": {
          "type": "boolean"
        },
        "minimumMermaidBlocks": {
          "type": "integer",
          "minimum": 0
        },
        "allowedDiagramTypes": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        },
        "views": {
          "type": "array",
          "items": {
            "enum": [
              "system",
              "domain",
              "component",
              "flow",
              "catalog",
              "platform",
              "engineering",
              "operations"
            ]
          },
          "uniqueItems": true
        },
        "catalogs": {
          "type": "object",
          "properties": {
            "shardBy": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "maximumRowsPerPage": {
              "type": "integer",
              "minimum": 1
            },
            "maximumBytesPerPage": {
              "type": "integer",
              "minimum": 1
            }
          },
          "additionalProperties": false
        },
        "evidence": {
          "type": "object",
          "properties": {
            "include": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "exclude": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "cacheDirectory": {
              "type": "string"
            },
            "maxFileBytes": {
              "type": "integer",
              "minimum": 1
            }
          },
          "additionalProperties": false
        },
        "frontMatterPolicy": {
          "enum": ["strict", "namespaced"]
        },
        "requireVerifiedEvidence": {
          "type": "boolean"
        },
        "requireCatalogIdentity": {
          "type": "boolean"
        },
        "requireRelationshipEvidence": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "mermaid": {
      "type": "object",
      "properties": {
        "mode": {
          "enum": [
            "basic",
            "render",
            "off"
          ]
        },
        "command": {
          "type": "string"
        },
        "args": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "timeoutSeconds": {
          "type": "integer",
          "minimum": 1
        },
        "cacheDirectory": {
          "type": "string"
        },
        "maxWorkers": {
          "type": "integer",
          "minimum": 1
        }
      },
      "additionalProperties": false
    },
    "components": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/component"
      }
    },
    "documentationUnits": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/documentationUnit"
      }
    },
    "system": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "id": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "output": {
          "type": "string"
        },
        "factsPath": {
          "type": "string"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    }
  },
  "$defs": {
    "component": {
      "type": "object",
      "required": [
        "id",
        "type",
        "repository"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "minLength": 1,
          "description": "Built-in types auto-select a profile; custom types may use an explicit profile and otherwise fall back to generic."
        },
        "profile": {
          "enum": [
            "application",
            "modular-application",
            "reusable",
            "infrastructure",
            "configuration",
            "contracts",
            "generic"
          ]
        },
        "repository": {
          "type": "string",
          "minLength": 1
        },
        "scope": {
          "type": "string"
        },
        "enabled": {
          "type": "boolean"
        },
        "includeInSystem": {
          "type": "boolean"
        },
        "group": {
          "type": "string"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "dependsOn": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "owners": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "capabilities": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "packs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "documentationUnit": {
      "type": "object",
      "required": [
        "id",
        "component",
        "kind",
        "output"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "component": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "enum": [
            "component",
            "domain",
            "flow",
            "catalog",
            "platform",
            "engineering",
            "operations"
          ]
        },
        "sourceRoots": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "relatedUnits": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "output": {
          "type": "string",
          "minLength": 1
        },
        "owners": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "capabilities": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "criticality": {
          "type": "string"
        },
        "domain": {
          "type": "string"
        },
        "subdomain": {
          "type": "string"
        },
        "boundedContext": {
          "type": "string"
        },
        "view": {
          "type": "string"
        },
        "evidenceRoots": {
          "type": "array",
          "items": { "type": "string" }
        },
        "shardBy": {
          "type": "array",
          "items": { "type": "string" }
        },
        "maximumRows": {
          "type": "integer",
          "minimum": 1
        }
      },
      "additionalProperties": false
    }
  }
}
